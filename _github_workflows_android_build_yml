# file_name: android_build.yml
# _github_workflows_android_build_yml
# This is a basic workflow to help you get started with Actions
# Android CI and CD
name: Android Build
# Controls when the workflow will run
on:
  # Triggers the workflow on push or pull request events but only for the "master" branch
  pull_request:
    branches: ["build"]
  push:
    branches: ["build"]
#  workflow_run:
#    workflows: ["Clear Caches 1"]
#    types:
#      - completed

  workflow_dispatch:

permissions:
  actions: write

# A workflow run is made up of one or more jobs that can run sequentially or in parallel
jobs:
  # This workflow contains a single job called "build"
  build:
    # The type of runner that the job will run on
    runs-on: ubuntu-latest
    # Steps represent a sequence of tasks that will be executed as part of the job
    steps:
      # Checks-out your repository under $GITHUB_WORKSPACE, so your job can access it
      - name: Checkout
        uses: actions/checkout@v6 #v4.1.1

      - name: Setup Java JDK
        uses: actions/setup-java@v5 #v4.0.0
        with:
          java-version: 17 # 25 26
          distribution: 'temurin' # 'adopt'

      # Permission Denied: If the runner cannot execute ./gradlew, you may need to fix file permissions in your repository by running git update-index --chmod=+x gradlew locally, then committing the change.
      - name: Change wrapper permissions
        run: chmod +x ./gradlew

      # Runs a single command using the runners shell
      - name: Build with Gradle
        run: ./gradlew build --no-daemon
#        run: ./gradlew wrapper --gradle-version=8.0 --distribution-type=bin

      - name: 'Tar files'
        run: tar -cvf my_files.tar app/build/outputs

      - name: Upload a Build Artifact
        uses: actions/upload-artifact@v7
        with:
          name: my_files.tar
          include-hidden-files: false
          path: my_files.tar
#          path: app/build/outputs/apk/debug/app-debug.apk
          archive: false

